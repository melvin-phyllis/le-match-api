PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/lematch
JWT_SECRET=change_this_secret
# Même projet Firebase que google-services.json (Android). Compte de service : Console > Paramètres > Comptes de service > Générer clé JSON.
# private_key sur une ligne, retours ligne = \n entre guillemets doubles :
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
ALLOWED_ORIGINS=http://localhost:3000
BASE_URL=http://192.168.1.73:3000

# Préfixe pour déploiement sous un sous-chemin (ex: /le-match-api)
# Laisser vide si l'API est à la racine du domaine
# BASE_PATH=/le-match-api

# Logs (optionnel) — par défaut: logs/app.log dans le répertoire du projet
# Sur cPanel, ex: LOG_FILE=/home/username/logs/lematch.log
# LOG_DIR=logs
# LOG_FILE=logs/app.log
